# Copy to .env and adjust. Local dev defaults to SQLite when DATABASE_URL is unset.
DJANGO_SETTINGS_MODULE=hearth.settings.dev
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Leave DATABASE_URL empty for SQLite (local dev). For Postgres (production):
# DATABASE_URL=postgres://hearth:hearth@127.0.0.1:5432/hearth
DATABASE_URL=

# Frontend origin for CORS
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
